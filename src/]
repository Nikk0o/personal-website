@import "variables.css";

body {
	margin: 0px;
	background-color: var(--bg-color);

	width: 100vw;
	height: 100vh;
}

.header {
	position: relative;
	background-color: var(--header-bg-color);
}

.header > nav {
	width: 100%;
	height: 30px;

	display: flex;
	justify-content: center;
	align-items: center;
	flex-wrap: wrap;
	gap: 6px;

	border-width: 1px 0px 1px 0px;
	border-style: solid;
	border-color: var(--text-color);
}

.header > nav > a, #exit-button {
	position: relative;

	font-family: "Courier New", Helvetica, monospace;
	font-size: 0.9em;

	color: var(--text-color);
	text-decoration: none;

	width: 15%;
	text-align: center;
}

.header > nav > a {
	border: 1px outset white;
	background-color: var(--header-bg-color);
}

#void-door {
	display: block;

	font-family: "Courier New", Helvetica, monospace;
	font-size: 0.9em;
	color: inherit;
	text-decoration: none;
	text-align: center;

	text-decoration: underline;

	width: 100%;

	background-color: var(--header-bg-color);
}

.header nav > a:hover, .door:hover, #void-door:hover {
	filter: invert(100%);
}

#exit-button {
	position: absolute;
	left: 0px;

	margin-left: 10px;
	margin-right: 20%;
}

.doors {
	flex-direction: column;
	align-items: stretch;
	gap: 7px;

	display: none;

	position: absolute;
	top: 100%;
	left: 0%;

	width: 100%;

	background-color: var(--header-bg-color);
}

.door {
	color: var(--text-color);
	text-decoration: none;

	background-color: inherit;
}

#exit-button:hover > .doors {
	display: flex;
}

.contents {
	margin: auto;

	width: 50%;
	height: 100%;

	border: 0px 2px 0px 2px;
	border-color: darkgray;
	border-style: none groove none groove;

	overflow: scroll;
}
